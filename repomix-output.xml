<file path="features/conditions/hooks/useUserConditions.tsx">
"use client"

import { useState, useEffect } from "react"
import { apiFetch } from "@/lib/api"

export function useUserConditions() {
  const [conditions, setConditions] = useState<any[]>([])
  const [filtered, setFiltered] = useState<any[]>([])
  const [selected, setSelected] = useState<any | null>(null)
  const [loading, setLoading] = useState(false)

  const fetchConditions = async () => {
    try {
      setLoading(true)

      const data = await apiFetch("/user-conditions")

      setConditions(data)
      setFiltered(data)

      setSelected((prev: any) =>
        prev
            ? data.find((c: any) => c.id === prev.id) || data[0]
            : data[0]
        )

    } catch (err) {
      console.error(err)
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    fetchConditions()
  }, [])

  const search = (query: string) => {
    const filteredData = conditions.filter((c) =>
      c.condition?.name?.toLowerCase().includes(query.toLowerCase())
    )

    setFiltered(filteredData)

    if (filteredData.length > 0) {
      setSelected(filteredData[0])
    } else {
      setSelected(null)
    }
  }

  return {
    conditions,
    filtered,
    selected,
    setSelected,
    fetchConditions,
    search,
    loading,
  }
}
</file>

